#!/usr/bin/env bash
set -euo pipefail

tmux_cmd() {
  local default_socket
  default_socket="/private/tmp/tmux-$(id -u)/default"
  local tmux_bin="tmux"

  if [[ -x "/opt/homebrew/bin/tmux" ]]; then
    tmux_bin="/opt/homebrew/bin/tmux"
  elif [[ -x "/usr/local/bin/tmux" ]]; then
    tmux_bin="/usr/local/bin/tmux"
  fi

  if [[ -n "${TMUX_SOCKET:-}" ]]; then
    "$tmux_bin" -S "$TMUX_SOCKET" "$@"
  elif [[ -S "$default_socket" ]]; then
    "$tmux_bin" -S "$default_socket" "$@"
  else
    "$tmux_bin" "$@"
  fi
}

# LLM presence is detected PRIMARILY from the terminal title (see the title
# helpers below and the classification order in window_status). Claude Code and
# Codex animate/label their titles, and their pane_current_command is an
# unstable value (Claude reports a version string such as "2.1.198", not
# "claude"), so they are matched by title, not command. This list is only a
# fallback for CLIs that expose a stable process name. Do NOT add version
# strings here - fix the title matchers instead.
is_llm_command() {
  case "$1" in
    codex | claude | gemini | aider | opencode)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

has_spinner_title() {
  case "$1" in
    # Braille spinner frames (U+2800-U+28FF). Claude Code animates the terminal
    # title with braille dots while actively working, and the classic dot
    # spinner lives in the same block. Matching the UTF-8 byte prefixes (E2 A0
    # through E2 A3) covers every frame without depending on which one is shown.
    $'\xe2\xa0'* | $'\xe2\xa1'* | $'\xe2\xa2'* | $'\xe2\xa3'*)
      return 0
      ;;
    # Circle / ASCII spinners (glyph followed by a space).
    "◐ "* | "◓ "* | "◑ "* | "◒ "* | "- "* | "\\ "* | "| "* | "/ "*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

spinner_frame() {
  local frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
  local index
  index=$(($(date +%s) % ${#frames[@]}))
  printf '%s' "${frames[$index]}"
}

is_codex_title() {
  [[ "$1" == \[*\]\ *\|* ]]
}

is_claude_title() {
  # Claude Code shows a static "✳ " prefix (U+2733) while present but idle /
  # awaiting input. The animated braille frames (handled by has_spinner_title)
  # cover the actively-working state.
  case "$1" in
    "✳ "* | "✳"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_waiting_title() {
  case "$1" in
    *"Action Required"* | *"Ready"* | *"Idle"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_active_title() {
  case "$1" in
    *"Thinking"* | *"Working"* | *"Running"* | *"Processing"* | *"Executing"* | *"Loading"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# Scan a window's panes and echo three space-separated counts:
# "<active> <present> <waiting>" = working / present-but-idle / awaiting-input.
count_window() {
  local target="${1:?window target required}"
  local active=0 present=0 waiting=0 command title

  while IFS=$'\t' read -r command title; do
    if has_spinner_title "${title:-}"; then
      active=$((active + 1))
    elif is_active_title "${title:-}"; then
      active=$((active + 1))
    elif is_waiting_title "${title:-}"; then
      waiting=$((waiting + 1))
    elif is_codex_title "${title:-}"; then
      present=$((present + 1))
    elif is_claude_title "${title:-}"; then
      present=$((present + 1))
    elif is_llm_command "${command##*/}"; then
      present=$((present + 1))
    fi
  done < <(tmux_cmd list-panes -t "$target" -F '#{pane_current_command}	#{pane_title}' 2>/dev/null || true)

  # Trailing newline is required: callers use `read`, which returns non-zero at
  # EOF without one, and under `set -e` that would silently abort the caller.
  printf '%d %d %d\n' "$active" "$present" "$waiting"
}

# Per-window marker, by precedence: working (spinner) > present (diamond) >
# waiting (bang). A count suffix is added when more than one pane qualifies.
format_marker() {
  local active="$1" present="$2" waiting="$3"

  if (( active > 0 )); then
    if (( active == 1 )); then spinner_frame; else printf '%s%d' "$(spinner_frame)" "$active"; fi
  elif (( present > 0 )); then
    if (( present == 1 )); then printf '◆'; else printf '◆%d' "$present"; fi
  elif (( waiting > 0 )); then
    if (( waiting == 1 )); then printf '!'; else printf '!%d' "$waiting"; fi
  fi
}

# The single category a window contributes to the fleet roll-up: its dominant
# marker, same precedence as format_marker.
window_category() {
  local active="$1" present="$2" waiting="$3"
  if (( active > 0 )); then printf 'active'
  elif (( present > 0 )); then printf 'present'
  elif (( waiting > 0 )); then printf 'waiting'
  else printf 'none'
  fi
}

# Compact fleet roll-up across windows: working, present, waiting (zeros omitted).
format_fleet() {
  local active_w="$1" present_w="$2" waiting_w="$3" out=''

  if (( active_w > 0 )); then out="${out}$(spinner_frame)${active_w} "; fi
  if (( present_w > 0 )); then out="${out}◆${present_w} "; fi
  if (( waiting_w > 0 )); then out="${out}!${waiting_w} "; fi

  printf '%s' "${out% }"
}

window_status() {
  local target="${1:?window target required}"
  local active present waiting
  read -r active present waiting < <(count_window "$target")
  format_marker "$active" "$present" "$waiting"
}

fleet_summary() {
  local window active present waiting
  local active_w=0 present_w=0 waiting_w=0

  while IFS= read -r window; do
    [[ -n "$window" ]] || continue
    read -r active present waiting < <(count_window "$window")
    case "$(window_category "$active" "$present" "$waiting")" in
      active) active_w=$((active_w + 1)) ;;
      present) present_w=$((present_w + 1)) ;;
      waiting) waiting_w=$((waiting_w + 1)) ;;
    esac
  done < <(tmux_cmd list-windows -a -F '#{window_id}' 2>/dev/null || true)

  format_fleet "$active_w" "$present_w" "$waiting_w"
}

# Jump to the next window (after the current one, wrapping) that has an agent
# present but NOT actively working - i.e. one likely waiting on your reply.
next_waiting() {
  local current window active present waiting
  local windows=()

  current="$(tmux_cmd display-message -p '#{window_id}' 2>/dev/null || true)"
  while IFS= read -r window; do
    [[ -n "$window" ]] && windows+=("$window")
  done < <(tmux_cmd list-windows -a -F '#{window_id}' 2>/dev/null || true)

  local n=${#windows[@]}
  (( n > 0 )) || return 0

  local start=0 i
  for i in "${!windows[@]}"; do
    if [[ "${windows[$i]}" == "$current" ]]; then start=$i; break; fi
  done

  local off target
  for (( off = 1; off <= n; off++ )); do
    target="${windows[$(( (start + off) % n ))]}"
    read -r active present waiting < <(count_window "$target")
    if (( active == 0 )) && (( present > 0 || waiting > 0 )); then
      tmux_cmd select-window -t "$target" 2>/dev/null \
        || tmux_cmd switch-client -t "$target" 2>/dev/null || true
      return 0
    fi
  done

  tmux_cmd display-message 'No agents waiting on you' 2>/dev/null || true
}

update_all_windows() {
  local window active present waiting
  local active_w=0 present_w=0 waiting_w=0

  while IFS= read -r window; do
    [[ -n "$window" ]] || continue
    read -r active present waiting < <(count_window "$window")
    tmux_cmd set-option -wq -t "$window" @llm_status \
      "$(format_marker "$active" "$present" "$waiting")" 2>/dev/null || true
    case "$(window_category "$active" "$present" "$waiting")" in
      active) active_w=$((active_w + 1)) ;;
      present) present_w=$((present_w + 1)) ;;
      waiting) waiting_w=$((waiting_w + 1)) ;;
    esac
  done < <(tmux_cmd list-windows -a -F '#{window_id}' 2>/dev/null || true)

  tmux_cmd set-option -gq @llm_fleet "$(format_fleet "$active_w" "$present_w" "$waiting_w")" 2>/dev/null || true
}

run_daemon() {
  while true; do
    update_all_windows
    sleep 1
  done
}

pid_file() {
  printf '/tmp/tmux-llm-status-%s.pid' "${UID:-$(id -u)}"
}

start_daemon() {
  local pidfile pid
  pidfile="$(pid_file)"

  if [[ -f "$pidfile" ]]; then
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi

  nohup "$0" run >/dev/null 2>&1 &
  printf '%s\n' "$!" > "$pidfile"
}

stop_daemon() {
  local pidfile pid
  pidfile="$(pid_file)"
  pid="$(cat "$pidfile" 2>/dev/null || true)"

  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$pidfile"
}

case "${1:-}" in
  window)
    window_status "${2:-}"
    ;;
  summary)
    fleet_summary
    ;;
  next-waiting)
    next_waiting
    ;;
  once)
    update_all_windows
    ;;
  run)
    run_daemon
    ;;
  start)
    start_daemon
    ;;
  stop)
    stop_daemon
    ;;
  restart)
    stop_daemon
    start_daemon
    ;;
  *)
    printf 'Usage: %s window <target> | summary | next-waiting | once | start | stop | restart\n' "${0##*/}" >&2
    exit 2
    ;;
esac
